# 复制为 .env 后填写（.env 已被 .gitignore 忽略，不会提交）

# ---------- 必填（对话功能） ----------
# DeepSeek API Key: https://platform.deepseek.com/
LLM_API_KEY=

# ---------- 可选 ----------
# JWT 签名密钥（生产环境务必修改）
# JWT_SECRET_KEY=change-me-in-production-use-long-random-string

# 数据库（留空则使用 config 中的 SQLite）
# DATABASE_URL=
# PostgreSQL 示例:
# DATABASE_URL=postgresql+psycopg://voice_crm:voice_crm@localhost:5432/voice_crm

# 邮件工具 SMTP 密码
# SMTP_PASSWORD=

# Tavily 联网搜索（设置后自动启用 provider=tavily）
# TAVILY_API_KEY=

# HuggingFace 加速下载（大模型可选）
# HF_TOKEN=
# HF_HUB_ENABLE_HF_TRANSFER=1

# CORS 允许来源（逗号分隔，生产环境示例）
# CORS_ORIGINS=http://localhost:5173,http://localhost:8080
